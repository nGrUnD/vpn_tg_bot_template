BOT_TOKEN=123456:ABC-DEF...
# Только при отладке / «залипшем» .bot_poll.lock: не держать fcntl-лок (риск TelegramConflictError при двух poller)
# BOT_POLL_LOCK_DISABLE=1
# Как в vpn_template: localhost, без DATABASE_SSL (asyncpg по умолчанию)
DATABASE_URL=postgresql://vpn_bot:your_password@localhost:5432/raccster_vpn
# Только если Postgres требует TLS: DATABASE_SSL=require

CHANNEL_USERNAME=@raccsterVPN
CHANNEL_URL=https://t.me/raccsterVPN

# Пробный период (длительность в днях, подпись «Получить N …»)
TRIAL_DAYS=3
# Лимит трафика пробного периода в ГБ (0 = без лимита)
# TRIAL_TRAFFIC_GB=0

# Панель 3x-ui (https://github.com/MHSanaei/3x-ui) — один клиент с одним subId во все inbounds
#
# Вариант A — одна панель (как раньше):
# THREEXUI_BASE_URL=https://panel.example.com
# THREEXUI_USERNAME=admin
# THREEXUI_PASSWORD=secret
# THREEXUI_VLESS_SERVER=vpn.example.com
# THREEXUI_VLESS_PORT=443
# THREEXUI_INBOUND_ID=1
#
# Вариант B — несколько панелей (равномерная раздача trial по active/weight, как в vpn_template):
# THREEXUI_BACKENDS_JSON=[{"key":"nl","base_url":"https://nl.example.com","username":"admin","password":"x","weight":1},{"key":"de","base_url":"https://de.example.com","username":"admin","password":"y","weight":1}]
# THREEXUI_DEFAULT_KEY=nl
# Поля бэкенда: key, base_url, username, password; опционально vless_server, vless_port, inbound_id, weight (по умолчанию 1), enabled (true/false), title
# Оплата рублями без API: одна статическая ссылка на кнопке «Оплатить» (если не используете WATA_ACCESS_TOKEN).
# PAYMENT_RUB_CHECKOUT_URL=https://example.com/pay
#
# WATA H2H (платёжная ссылка + webhook): https://wata.pro/api
# Токен из ЛК мерчанта (Терминалы → токены). При наличии токена бот сам создаёт ссылку на оплату с orderId.
# WATA_ACCESS_TOKEN=
# Боевой API по умолчанию; песочница: https://api-sandbox.wata.pro/api/h2h
# WATA_API_BASE=https://api.wata.pro/api/h2h
#
# Публичный HTTPS endpoint для webhook (в ЛК WATA укажите URL вида https://ваш-домен/webhooks/wata).
# HTTP_WEBHOOK_HOST=0.0.0.0
# HTTP_WEBHOOK_PORT=8080
# Путь POST (должен совпадать с настройкой в ЛК): WATA_WEBHOOK_PATH=/webhooks/wata
# Для отладки без проверки подписи: WATA_WEBHOOK_VERIFY_SIGNATURE=false

# Подробные инструкции (кнопки на экранах iPhone / Android)
# IPHONE_INSTRUCTION_URL=https://example.com/ios-howto
# ANDROID_INSTRUCTION_URL=https://example.com/android-howto